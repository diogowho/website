---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import { SELF, SOCIALS } from "../consts";
import Link from "../components/Link.astro";
import { Icon } from "astro-icon/components";
---

<Layout description="Diogo's chaotic corner of the web.">
  <Container>
    <aside>
      <div class="flex items-center gap-x-4">
        <img
          src="https://codeberg.org/diogocastro.png"
          alt={`${SELF.name}'s profile picture on Codeberg`}
          class="h-20 w-20 rounded-full"
        />
        <h1
          class="font-pecita text-3xl font-semibold text-black dark:text-white"
        >
          Diogo Castro
        </h1>
      </div>
      <div class="space-y-12">
        <section>
          <article class="space-y-4">
            <span>
              <p>
                Computer science undergraduate at the <Link
                  href="https://estsetubal.ips.pt/"
                  >Polytechnic Institute of Setúbal</Link
                >. When I'm not having classes, I'm usually messing with
                computers, networking, learning new things, shitposting or
                lurking online.
              </p>
              <p>
                I operate <Link href="https://as207118.net">AS207118</Link> and spend
                too much time perfecting my <Link
                  href="https://flake.diogocastro.net">Nix flake</Link
                >.
              </p>
            </span>
          </article>
        </section>

        <section class="space-y-4">
          <h2 class="font-semibold text-black dark:text-white">
            You can find me on:
          </h2>
          <ul class="not-prose flex flex-wrap gap-2">
            {
              SOCIALS.map((SOCIAL) => (
                <li>
                  <Link
                    href={SOCIAL.href}
                    external
                    rel="me"
                    aria-label={`${SELF.name} on ${SOCIAL.name}`}
                    class="flex items-center gap-x-2 text-nowrap"
                  >
                    {SOCIAL.icon && (
                      <Icon name={SOCIAL.icon} class="mr-1 inline" />
                    )}
                    <span>{SOCIAL.name}</span>
                  </Link>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </aside>
  </Container>
</Layout>
