---
import Layout from "../layouts/Default.astro";
import pkg from "../../package.json";

const astroVersion = pkg.dependencies.astro.replace(/^[^0-9]+/, "");

const pages = [
  { name: "AS207118", url: "https://as207118.net" },
  { name: "Privacy", url: "/privacy" },
  { name: "Transparency", url: "/transparency" },
  { name: "AI", url: "/ai" },
];

const socials = [
  { name: "Codeberg", url: "https://codeberg.org/diogocastro" },
  {
    name: "Fedi",
    url: "https://dissociat.ing/@iz",
  },
  {
    name: "Steam",
    url: "https://steamcommunity.com/profiles/76561198950840617",
  },
  { name: "Email", url: "mailto:website@diogocastro.net" },
  {
    name: "Signal",
    url: "https://signal.me/#eu/fsBt9oTZ4lxcqA7hHvjot1ft2C91k6ysxLETTqMYf5VECufwnq9C_YlbMkIlQ4ra",
  },
  {
    name: "Matrix",
    url: "https://matrix.to/#/@iz:skji.org",
  },
];
---

<Layout title="Diogo Castro">
  <Fragment slot="head">
    <meta name="title" content="Diogo Castro" />
    <meta
      name="description"
      content="Diogo Castro's chaotic corner of the web."
    />
    <meta
      name="keywords"
      content="Diogo Castro, Diogo, Castro, Computer Science, Developer, Programmer, Portugal, Setúbal, IPS, Polytechnic Institute of Setúbal, Software Engineer, Web Developer, GitHub, diogowho, networking, technology"
    />
    <meta name="author" content="Diogo Castro" />
    <link rel="canonical" href="https://diogocastro.net" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://diogocastro.net" />
    <meta property="og:title" content="Diogo Castro" />
    <meta
      property="og:description"
      content="Diogo Castro's chaotic corner of the web."
    />
    <meta property="og:image" content="https://github.com/diogowho.png" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Diogo Castro" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Diogo Castro",
        "url": "https://diogocastro.net",
        "image": "https://codeberg.org/diogocastro.png",
        "jobTitle": "Computer Science Student",
        "description": "Computer Science undergraduate at the Polytechnic Institute of Setúbal, Portugal",
        "alumniOf": {
          "@type": "EducationalOrganization",
          "name": "Polytechnic Institute of Setúbal"
        },
        "nationality": {
          "@type": "Country",
          "name": "Portugal"
        },
        "sameAs": [
          "https://github.com/diogowho",
          "https://codeberg.org/diogocastro",
          "https://steamcommunity.com/profiles/76561198950840617",
          "https://bsky.app/profile/did:plc:unut65tqbd4kvczdh24tazwm"
        ],
        "email": "website@diogocastro.net"
      }
    </script>

    <link rel="sitemap" href="/sitemap-index.xml" />
  </Fragment>

  <header
    slot="header"
    class="mb-8 flex flex-col items-start gap-6 sm:flex-row sm:items-center"
  >
    <img
      src="https://codeberg.org/diogocastro.png"
      alt="diogo castro"
      class="h-20 w-20 rounded-full"
    />
    <h1 class="font-pecita text-2xl tracking-tighter">Diogo Castro</h1>
  </header>

  <section class="mb-8">
    <p class="mb-2">
      Computer science undergraduate at the <a
        href="https://estsetubal.ips.pt/"
        class="text-inherit underline decoration-1 hover:no-underline"
        >Polytechnic Institute of Setúbal</a
      >. When I'm not having classes, I'm usually messing with computers,
      networking, learning new things, shitposting or lurking online.
    </p>

    <p class="mb-4">
      I started writing code at the age of 9, and have been passionate about
      tech ever since. I also enjoy gaming casually.
    </p>
  </section>

  <section class="mb-8">
    <h2 class="mb-2 text-base font-bold text-[#888888]">Pages</h2>
    <nav class="flex flex-wrap gap-4">
      {
        pages.map((page) => (
          <a
            href={page.url}
            class="text-inherit underline decoration-1 hover:no-underline"
          >
            {page.name}
          </a>
        ))
      }
    </nav>
  </section>

  <section class="mb-8">
    <h2 class="mb-2 text-base font-bold text-[#888888]">Socials</h2>
    <nav class="flex flex-wrap gap-4">
      {
        socials.map((social) =>
          social.url ? (
            <a
              href={social.url}
              rel={social.rel}
              title={social.title}
              class="text-inherit underline decoration-1 hover:no-underline"
            >
              {social.name}
            </a>
          ) : (
            <span class={social.class} title={social.title}>
              {social.name}
            </span>
          ),
        )
      }
    </nav>
  </section>

  <footer class="text-[10px] text-[#888888]">
    <p>Astro v{astroVersion}</p>
  </footer>
</Layout>
