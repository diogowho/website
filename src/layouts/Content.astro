---
import Layout from "./Default.astro";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} showBackLink={frontmatter.showBackLink}>
  <div class="markdown-content">
    <slot />
  </div>
</Layout>

<style is:global>
  @reference "../styles/globals.css";

  .markdown-content h2 {
    @apply mt-6 mb-2 text-base font-bold text-[#888888];
  }
  .markdown-content h2:first-child {
    @apply mt-0;
  }
  .markdown-content h3 {
    @apply mt-3 mb-2 text-base font-semibold text-[#888888];
  }
  .markdown-content h3:first-child {
    @apply mt-0;
  }
  .markdown-content p {
    @apply mb-4;
  }
  .markdown-content ul {
    list-style-type: disc;
    padding-left: 1.25rem;
  }
  .markdown-content li {
    @apply pt-0.5;
  }
</style>
