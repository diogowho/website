---
import "../styles/globals.css";

interface Props {
  title: string;
  showBackLink?: boolean;
  bodyClass?: string;
  mainClass?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  url?: string;
  type?: string;
}

const {
  title,
  showBackLink = false,
  bodyClass = "flex min-h-screen items-center justify-center p-8",
  mainClass = "w-full max-w-[600px]",
  description = "Diogo Castro's chaotic corner of the web.",
  keywords = [
    "Diogo Castro",
    "Diogo",
    "Castro",
    "Computer Science",
    "Developer",
    "Programmer",
    "Portugal",
    "Setúbal",
    "IPS",
    "Polytechnic Institute of Setúbal",
    "Software Engineer",
    "Web Developer",
    "diogowho",
    "networking",
    "technology",
    "AS207118",
  ],
  type = "website",
  url = Astro.request.url,
} = Astro.props;

const pageTitle = title === "Diogo Castro" ? title : `${title} | Diogo Castro`;
---

<html
  lang="en"
  class="font-mono text-sm leading-normal"
  style="color-scheme: light dark;"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content="Diogo Castro" />
    <link rel="canonical" href={url} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Diogo Castro" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Diogo Castro",
        "url": "https://diogocastro.net",
        "image": "https://codeberg.org/diogocastro.png",
        "jobTitle": "Computer Science Student",
        "description": "Computer Science undergraduate at the Polytechnic Institute of Setúbal, Portugal",
        "alumniOf": {
          "@type": "EducationalOrganization",
          "name": "Polytechnic Institute of Setúbal"
        },
        "nationality": {
          "@type": "Country",
          "name": "Portugal"
        },
        "sameAs": [
          "https://github.com/diogowho",
          "https://codeberg.org/diogocastro",
          "https://steamcommunity.com/profiles/76561198950840617",
          "https://dissociat.ing/@iz"
        ],
        "email": "website@diogocastro.net"
      }
    </script>

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class={bodyClass}>
    <main class={mainClass}>
      <slot name="header">
        <header class="mb-6">
          <h1 class="text-2xl font-normal tracking-tighter">{title}</h1>
          {
            showBackLink && (
              <a href="/" class="text-[#888888] hover:underline">
                ← Back to home
              </a>
            )
          }
        </header>
      </slot>
      <slot />
    </main>
  </body>
</html>
